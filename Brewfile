# Brewfile — macOS dependencies for scaffold dotfiles
# Usage: brew bundle --file=Brewfile

brew "bash"          # >= 4.0 (system bash 3.2 is too old)
brew "eza"           # modern ls replacement
brew "fzf"           # fuzzy finder
brew "starship"      # prompt
brew "zoxide"        # smarter cd
brew "git"           # should already be installed by Xcode CLT
