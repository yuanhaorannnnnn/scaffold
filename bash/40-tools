# =============================================================================
# 40-tools — Third-party tool initializations
# =============================================================================

# --- Google Cloud SDK -------------------------------------------------------
if [ -f "$HOME/software/google-cloud-sdk/path.bash.inc" ]; then
    . "$HOME/software/google-cloud-sdk/path.bash.inc"
fi
if [ -f "$HOME/software/google-cloud-sdk/completion.bash.inc" ]; then
    . "$HOME/software/google-cloud-sdk/completion.bash.inc"
fi

# --- Conda ------------------------------------------------------------------
__conda_setup="$('/home/lkshpc/anaconda3/bin/conda' 'shell.bash' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/home/lkshpc/anaconda3/etc/profile.d/conda.sh" ]; then
        . "/home/lkshpc/anaconda3/etc/profile.d/conda.sh"
    else
        export PATH="/home/lkshpc/anaconda3/bin:$PATH"
    fi
fi
unset __conda_setup

# --- FZF --------------------------------------------------------------------
[ -f /usr/share/doc/fzf/examples/key-bindings.bash ] && \
    source /usr/share/doc/fzf/examples/key-bindings.bash

# --- Starship prompt --------------------------------------------------------
command -v starship >/dev/null 2>&1 && eval "$(starship init bash)"

# --- Zoxide -----------------------------------------------------------------
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init bash)"
