# =============================================================================
# secrets — API keys and tokens (DO NOT COMMIT)
# Copy this file to `secrets` and fill in your real values:
#   cp secrets.example secrets
# =============================================================================

# export GITHUB_PERSONAL_ACCESS_TOKEN="ghp_xxxxxxxx"
# export NUREC_IMAGE="docker.io/carlasimulator/nvidia-nurec-grpc:0.2.0"
# export HF_TOKEN="hf_xxxxxxxx"

# Claude Code provider switcher (`claude-switch`)
# Official Anthropic API:
# export CLAUDE_ANTHROPIC_API_KEY="sk-ant-xxxxxxxx"
# export CLAUDE_ANTHROPIC_MODEL="claude-sonnet-4-5"

# Kimi Anthropic-compatible endpoint:
# export KIMI_API_KEY="sk-xxxxxxxx"
# export KIMI_ANTHROPIC_BASE_URL="https://your-kimi-anthropic-endpoint"
# export KIMI_ANTHROPIC_MODEL="your-kimi-model"
# export KIMI_ANTHROPIC_DEFAULT_OPUS_MODEL="your-kimi-opus-model"
# export KIMI_ANTHROPIC_DEFAULT_SONNET_MODEL="your-kimi-sonnet-model"
# export KIMI_ANTHROPIC_DEFAULT_HAIKU_MODEL="your-kimi-haiku-model"
# export KIMI_CLAUDE_CODE_SUBAGENT_MODEL="your-kimi-haiku-model"
# export KIMI_CLAUDE_CODE_EFFORT_LEVEL="max"

# DeepSeek Anthropic-compatible endpoint:
# export DEEPSEEK_API_KEY="sk-xxxxxxxx"
# export DEEPSEEK_ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
# export DEEPSEEK_ANTHROPIC_MODEL="deepseek-v4-pro[1m]"
# export DEEPSEEK_ANTHROPIC_DEFAULT_OPUS_MODEL="deepseek-v4-pro[1m]"
# export DEEPSEEK_ANTHROPIC_DEFAULT_SONNET_MODEL="deepseek-v4-pro[1m]"
# export DEEPSEEK_ANTHROPIC_DEFAULT_HAIKU_MODEL="deepseek-v4-flash"
# export DEEPSEEK_CLAUDE_CODE_SUBAGENT_MODEL="deepseek-v4-flash"
# export DEEPSEEK_CLAUDE_CODE_EFFORT_LEVEL="max"
