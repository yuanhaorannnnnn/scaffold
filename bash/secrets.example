# =============================================================================
# secrets — API keys and tokens (DO NOT COMMIT)
# Copy this file to `secrets` and fill in your real values:
#   cp secrets.example secrets
# =============================================================================

# export GITHUB_PERSONAL_ACCESS_TOKEN="ghp_xxxxxxxx"
# export NUREC_IMAGE="docker.io/carlasimulator/nvidia-nurec-grpc:0.2.0"
# export HF_TOKEN="hf_xxxxxxxx"

# Claude Code provider switcher (`claude-switch`) — plain shell vars (no export).
# claude-switch sources this file directly, so export is unnecessary and would
# leak provider credentials into Codex subprocesses via shell environment.
# Official Anthropic API:
# CLAUDE_ANTHROPIC_API_KEY="sk-ant-xxxxxxxx"
# CLAUDE_ANTHROPIC_MODEL="claude-sonnet-4-5"

# Kimi Anthropic-compatible endpoint:
# KIMI_API_KEY="sk-xxxxxxxx"
# KIMI_ANTHROPIC_BASE_URL="https://your-kimi-anthropic-endpoint"
# KIMI_ANTHROPIC_MODEL="your-kimi-model"
# KIMI_ANTHROPIC_DEFAULT_OPUS_MODEL="your-kimi-opus-model"
# KIMI_ANTHROPIC_DEFAULT_SONNET_MODEL="your-kimi-sonnet-model"
# KIMI_ANTHROPIC_DEFAULT_HAIKU_MODEL="your-kimi-haiku-model"
# KIMI_CLAUDE_CODE_SUBAGENT_MODEL="your-kimi-haiku-model"
# KIMI_CLAUDE_CODE_EFFORT_LEVEL="max"

# DeepSeek Anthropic-compatible endpoint:
# DEEPSEEK_API_KEY="sk-xxxxxxxx"
# DEEPSEEK_ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
# DEEPSEEK_ANTHROPIC_MODEL="deepseek-v4-pro[1m]"
# DEEPSEEK_ANTHROPIC_DEFAULT_OPUS_MODEL="deepseek-v4-pro[1m]"
# DEEPSEEK_ANTHROPIC_DEFAULT_SONNET_MODEL="deepseek-v4-pro[1m]"
# DEEPSEEK_ANTHROPIC_DEFAULT_HAIKU_MODEL="deepseek-v4-flash"
# DEEPSEEK_CLAUDE_CODE_SUBAGENT_MODEL="deepseek-v4-flash"
# DEEPSEEK_CLAUDE_CODE_EFFORT_LEVEL="max"
